{
  "version": 2,
  "theme": "builtin://dark",
  "check_for_updates": false,
  "active_keybinding_map": "vscode",
  "keybindings": [
    {
      "key": "p",
      "modifiers": [
        "ctrl"
      ],
      "action": "file_finder::Toggle"
    },
    {
      "key": "p",
      "modifiers": [
        "ctrl",
        "shift"
      ],
      "action": "command_palette::Toggle"
    }
  ],
  "lsp": {
    "nixd": {
      "settings": {
        "nixpkgs": {
          "expr": "import <nixpkgs> { }"
        },
        "formatting": {
          "command": [ "nixfmt" ]
        }
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  }
}
